# ===========================================
# OntoCast Environment Configuration
# Copy this file to .env and update with your values
# ===========================================

# Domain Configuration
# Used for URI generation in the knowledge graph
CURRENT_DOMAIN=https://example.com

# Server Configuration
PORT=8999
BASE_RECURSION_LIMIT=1000
ESTIMATED_CHUNKS=30
MAX_VISITS=1
RENDER_MODE=ontology_and_facts
LLM_GRAPH_FORMAT=turtle
ONTOLOGY_CONTEXT_MODE=selected_single_ontology
#ONTOLOGY_CONTEXT_FIXED_ONTOLOGY_ID=my_ontology_id
ONTOLOGY_MAX_TRIPLES=50000
PARALLEL_WORKERS=4
PARALLEL_FACTS_RETRIES=3
PARALLEL_ONTOLOGY_RETRIES=3
ENABLE_ONTOLOGY_CONSOLIDATION=false

# LLM Configuration
# Available providers: openai, ollama, anthropic, google
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_API_KEY=your_openai_api_key_here
# LLM_CACHE_ENABLED=true
# LLM_CACHE_READ_ONLY=false
# LLM_MAX_INFLIGHT=16
# MAX_CONCURRENT_PROCESSES=4

# Ollama Configuration (Alternative)
# LLM_PROVIDER=ollama
# LLM_MODEL_NAME=llama3.1
# LLM_BASE_URL=http://localhost:11434
# LLM_TEMPERATURE=0.0

# Anthropic Claude (Alternative)
# LLM_PROVIDER=anthropic
# LLM_MODEL_NAME=claude-sonnet-4-20250514
# LLM_API_KEY=your_anthropic_api_key_here
# LLM_TEMPERATURE=0.0

# Google Gemini (Alternative)
# LLM_PROVIDER=google
# LLM_MODEL_NAME=gemini-2.0-flash
# LLM_API_KEY=your_google_api_key_here
# LLM_TEMPERATURE=0.0

# Chunking Configuration
CHUNK_BREAKPOINT_THRESHOLD_TYPE=percentile
CHUNK_BREAKPOINT_THRESHOLD_AMOUNT=95.0
CHUNK_MIN_SIZE=3000
CHUNK_MAX_SIZE=12000
CHUNK_SECTION_TAG_MIN_CHARS=80

# Triple Store Configuration
# Fuseki is preferred over Neo4j when both are configured.
# If no triple store is configured, OntoCast uses filesystem storage.
# When FUSEKI_DATASET is unset, names derive from default tenant/project (ontocast/test).

# Fuseki Configuration (Recommended)
# Server root only — SPARQL is at {FUSEKI_URI}/{dataset}/sparql (not the UI link "#/dataset/…").
FUSEKI_URI=http://localhost:3030
FUSEKI_AUTH=admin/admin
#FUSEKI_DATASET=ontocast--test--facts
#FUSEKI_ONTOLOGIES_DATASET=ontocast--test--ontologies

# Path Configuration
ONTOCAST_WORKING_DIRECTORY=/path/to/working/directory
ONTOCAST_ONTOLOGY_DIRECTORY=/path/to/ontology/files
# optional; uses platform cache directory when unset
ONTOCAST_CACHE_DIR=/path/to/cache/directory

# Aggregation (entity disambiguation across chunks)
AGG_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
AGG_SIMILARITY_THRESHOLD=0.80

# Embedding provider (vector store / retrieval)
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_DIMENSION=384

# Qdrant connection (optional; use QDRANT_URI or LANCEDB_ENABLED, not both)
QDRANT_URI=http://localhost:6333
QDRANT_API_KEY=abc123-qwe
# Default collections derive from tenant/project ontocast/test when unset.
QDRANT_GRPC_PORT=6334
QDRANT_USE_GRPC=false

# Vector store retrieval (backend-agnostic; applies to Qdrant and LanceDB)
VECTOR_STORE_TOP_K=10
VECTOR_STORE_INDUCED_SUBGRAPH_DEPTH=1
VECTOR_STORE_INDUCED_SUBGRAPH_MAX_TOTAL_TRIPLES=300
VECTOR_STORE_INDUCED_SUBGRAPH_ESTIMATED_TRIPLES_PER_QUERY=24

# Embedded LanceDB alternative (optional; local directory via lancedb.connect)
# LANCEDB_ENABLED=true
# LANCEDB_DATA_DIR=~/.lancedb_data

# Ontology patch retrieval (post-vector scoring; backend-agnostic)
ONTOLOGY_PATCH_PER_QUERY_CORE_SCORE_RATIO=0.85
ONTOLOGY_PATCH_PER_QUERY_NEIGHBORHOOD_SCORE_RATIO=0.85
# ONTOLOGY_PATCH_MIN_CORE_QUERY_BEST_SCORE=0.0
# ONTOLOGY_PATCH_MIN_NEIGHBORHOOD_QUERY_BEST_SCORE=0.0
ONTOLOGY_PATCH_MIN_MERGED_MAX_SCORE=0.18
# ONTOLOGY_PATCH_MERGED_SCORE_RATIO=0.0
# ONTOLOGY_PATCH_MMR_LAMBDA=0.7
# ONTOLOGY_PATCH_MAX_ATOMS=0

# Web grounding (search-later: nodes run without search first)
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=duckduckgo
WEB_SEARCH_TOP_K=3
WEB_SEARCH_TIMEOUT_SECONDS=8.0
WEB_SEARCH_MAX_SNIPPET_CHARS=400
WEB_SEARCH_MAX_TOTAL_CHARS=1800
WEB_SEARCH_ONTOLOGY_RENDER_ENABLED=true
WEB_SEARCH_ONTOLOGY_CRITIC_ENABLED=true
WEB_SEARCH_FACTS_RENDER_ENABLED=false
WEB_SEARCH_FACTS_CRITIC_ENABLED=false
WEB_SEARCH_PLANNER_ENABLED=true
WEB_SEARCH_PLANNER_MAX_QUERIES=3
WEB_SEARCH_PLANNER_MIN_QUERY_CHARS=12
WEB_SEARCH_PLANNER_MIN_CONFIDENCE=0.35
WEB_SEARCH_REUSE_EVIDENCE_ACROSS_ATTEMPT=true
WEB_SEARCH_MIN_SNIPPET_CHARS=40
WEB_SEARCH_ALLOWED_DOMAINS=
WEB_SEARCH_BLOCKED_DOMAINS=
WEB_SEARCH_REGION=wt-wt
WEB_SEARCH_SAFESEARCH=moderate

# Additional Configuration
# With --input-path: if true, flush triple store (configured scope) before processing.
CLEAN=false
LOGGING_LEVEL=info
